# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=miweb_db

# JWT (cambiar en producción)
JWT_SECRET=your-super-secret-key-change-in-production

# Server (API Go). Con React en Vite (5173): deja PORT=3000 y en frontend-react/.env.development
# usa VITE_BACKEND_URL=http://localhost:3000 para que el cliente llame al API directamente.
PORT=3000

# Storage (carpeta física que se expone como /storage/**)
# Ejemplo Linux: /home/cloudpanel/htdocs/zcontable.gestionweb.cloud/storage
STORAGE_PATH=./storage

# Tukifac (opcional; también en Configuración del estudio en la app)
TUKIFAC_BASE_URL=
TUKIFAC_API_TOKEN=
# Rutas POST para emitir comprobantes (ajustar si tu instancia usa otra ruta)
TUKIFAC_POST_DOCUMENTS_PATH=/api/documents
TUKIFAC_POST_SALE_NOTE_PATH=/api/sale-note
