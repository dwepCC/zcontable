# API Go (Fiber). Con Vite en 5173 las peticiones deben ir al puerto del backend, no a 5173.
# Ejecuta el servidor: en la raíz del repo con PORT=3000 (o el que uses en .env).
VITE_BACKEND_URL=http://localhost:3000

# Si prefieres solo proxy (sin URL absoluta), deja VITE_BACKEND_URL vacío y en vite.config.ts
# apunta el proxy al mismo puerto donde corre Go (p. ej. 3000 o 8080).
